{
    "_version": "1.49.0",
    "sap.app": {
        "id": "com.archivelabels.zesparchivelabels",
        "type": "application",
        "i18n": "i18n/i18n.properties",
        "applicationVersion": {
            "version": "0.0.1"
        },
        "title": "{{appTitle}}",
        "description": "{{appDescription}}",
        "resources": "resources.json",
        "sourceTemplate": {
            "id": "@sap/generator-fiori:basic",
            "version": "1.9.4",
            "toolsId": "f55ddbd0-c348-45c0-a5c5-d46377585887"
        },
        "dataSources": {
            "mainService": {
                "uri": "/sap/opu/odata/sap/ZGW_DOCUMENT_ARCHIVING_SRV/",
                "type": "OData",
                "settings": {
                    "annotations": [],
                    "localUri": "localService/metadata.xml",
                    "odataVersion": "2.0"
                }
            },
            "visibleRows": {
                "uri": "model/visibleRows.json",
                "type": "JSON"
            }
        },
        "crossNavigation": {
            "inbounds": {
                "com-archivelabels-zesparchivelabels-inbound": {
                    "signature": {
                        "parameters": {},
                        "additionalParameters": "allowed"
                    },
                    "semanticObject": "zesp_archivelabels_semobj",
                    "action": "Display",
                    "title": "{{flpTitle}}",
                    "subTitle": "{{flpSubtitle}}",
                    "icon": ""
                }
            }
        }
    },
    "sap.ui": {
        "technology": "UI5",
        "icons": {
            "icon": "",
            "favIcon": "",
            "phone": "",
            "phone@2": "",
            "tablet": "",
            "tablet@2": ""
        },
        "deviceTypes": {
            "desktop": true,
            "tablet": true,
            "phone": true
        }
    },
    "sap.ui5": {
        "flexEnabled": false,
        "dependencies": {
            "minUI5Version": "1.113.0",
            "libs": {
                "sap.m": {},
                "sap.ui.core": {},
                "sap.f": {},
                "sap.suite.ui.generic.template": {},
                "sap.ui.comp": {},
                "sap.ui.generic.app": {},
                "sap.ushell": {}
            }
        },
        "contentDensities": {
            "compact": true,
            "cozy": true
        },
        "models": {
            "i18n": {
                "type": "sap.ui.model.resource.ResourceModel",
                "settings": {
                    "bundleName": "com.archivelabels.zesparchivelabels.i18n.i18n"
                }
            },
            "searchDataModel": {
                "dataSource": "mainService",
                "preload": true,
                "settings": {
                    "useBatch": false
                }
            },
            "visibleRows": {
                "type": "sap.ui.model.json.JSONModel",
                "dataSource": "visibleRows",
                "preload": true
            }
        },
        "resources": {
            "css": [
                {
                    "uri": "css/style.css"
                }
            ]
        },
        "routing": {
            "config": {
                "routerClass": "sap.m.routing.Router",
                "viewType": "XML",
                "async": true,
                "viewPath": "com.archivelabels.zesparchivelabels.view",
                "controlAggregation": "pages",
                "controlId": "app",
                "clearControlAggregation": false
            },
            "routes": [
                {
                    "name": "RouteArchiveLabels",
                    "pattern": ":?query:",
                    "target": [
                        "TargetArchiveLabels"
                    ]
                }
            ],
            "targets": {
                "TargetArchiveLabels": {
                    "viewType": "XML",
                    "transition": "slide",
                    "clearControlAggregation": false,
                    "viewId": "ArchiveLabels",
                    "viewName": "ArchiveLabels"
                }
            }
        },
        "rootView": {
            "viewName": "com.archivelabels.zesparchivelabels.view.App",
            "type": "XML",
            "async": true,
            "id": "App"
        }
    },
    "sap.cloud": {
        "public": true,
        "service": "comarchivelabelszesparchivelabels"
    }
}